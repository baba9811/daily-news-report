# ============================================================
# Daily Scheduler - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# ============================================================

# === Email Configuration ===
# Gmail: Enable "App Passwords" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                    # your-email@gmail.com
SMTP_PASSWORD=                # Gmail app password (16 chars, no spaces)
EMAIL_FROM=                   # your-email@gmail.com
EMAIL_TO=["recipient@example.com"]

# === Claude Code CLI ===
CLAUDE_CLI_PATH=claude        # Path to claude CLI binary
CLAUDE_MODEL=opus           # Model: opus, sonnet, haiku

# === Finance APIs (Optional) ===
# NEWS_API_KEY=               # https://newsapi.org - Free: 100 req/day
# ALPHAVANTAGE_KEY=           # https://alphavantage.co - Free: 25 req/day

# === Report Language ===
# Controls the language of AI-generated reports and emails (ko, en, ja, etc.)
REPORT_LANGUAGE=ko

# === Timezone ===
# IANA timezone (e.g. Asia/Seoul, US/Eastern, Europe/London, UTC)
TIMEZONE=Asia/Seoul

# === Database ===
DATABASE_URL=sqlite:///data/daily_scheduler.db

# === Scheduler ===
SCHEDULE_TIME=07:30              # HH:MM in KST — Daily trading report time
NEWS_SCHEDULE_TIME=07:15         # HH:MM in KST — Korean news briefing time
GLOBAL_NEWS_SCHEDULE_TIME=07:00  # HH:MM in KST — Global news briefing time

# === Server ===
HOST=127.0.0.1
PORT=8000

# === Multica Integration (Plan 4) ===
# Run Multica locally with: docker compose -f docker-compose.multica.yml up -d
# Backend API base URL (issues/comments/health). Leave empty to disable.
MULTICA_BASE_URL=http://localhost:8080
# Web (board UI) URL embedded as an iframe on the /multica page.
MULTICA_WEB_URL=http://localhost:3001
# HMAC-SHA256 shared secret used to verify inbound webhooks from Multica.
# Set this to the Multica JWT_SECRET (or a dedicated shared secret).
MULTICA_WEBHOOK_SECRET=
# Outbound issue/comment posting needs a Multica Personal Access Token
# (mul_...) and the target workspace UUID. Bootstrap both with:
#   bash scripts/multica-bootstrap.sh
# Leave empty to keep the board read-only (health probe + iframe still work).
MULTICA_API_TOKEN=
MULTICA_WORKSPACE_ID=
